table refresh_sessions {
  id varchar(36) [pk, not null]
  user_id varchar(255) [not null]
  token_hash varchar(64) [not null, unique]
  expires_at timestamp [not null]
  created_at timestamp [not null, default: `(now())`]

  indexes {
    user_id [name: 'refresh_sessions_user_id_idx']
  }
}

table roles {
  key varchar(255) [pk, not null]
  display_name varchar(255) [not null]
}

table permission {
  key varchar(255) [pk, not null]
  display_name varchar(255) [not null]
}

table role_permission {
  role_key varchar(255) [not null]
  permission_key varchar(255) [not null]

  indexes {
    (role_key, permission_key) [pk]
  }
}

table app_user {
  id varchar(255) [pk, not null]
  name varchar(255) [not null]
  email varchar(255) [not null, unique]
  password varchar(255) [not null]
  role_key varchar(255) [not null]
  created_at timestamp [not null, default: `(now())`]
  updated_at timestamp [not null, default: `(now())`]
}

table product {
  id varchar(36) [pk, not null]
  name varchar(255) [not null]
  description text [not null]
  price int [not null, default: 0]
  created_at timestamp [not null, default: `(now())`]
  updated_at timestamp [not null, default: `(now())`]
}

table product_refiller {
  product varchar(36) [not null]
  refiller varchar(255) [not null]

  indexes {
    (product, refiller) [pk]
  }
}

table shelf {
  id varchar(36) [pk, not null]
  product_id varchar(36) [not null, unique]
  quantity int [not null, default: 0]
  created_at timestamp [not null, default: `(now())`]
  updated_at timestamp [not null, default: `(now())`]

  indexes {
    product_id [name: 'shelf_product_id_idx']
  }
}

table store_room {
  id varchar(36) [pk, not null]
  name varchar(255) [not null]
  description text
  created_at timestamp [not null, default: `(now())`]
  updated_at timestamp [not null, default: `(now())`]
}

table section {
  id varchar(36) [pk, not null]
  store_room_id varchar(36) [not null]
  name varchar(255) [not null]
  location varchar(255) [not null]
  description text
  created_at timestamp [not null, default: `(now())`]
  updated_at timestamp [not null, default: `(now())`]

  indexes {
    store_room_id [name: 'section_store_room_id_idx']
  }
}

table section_product {
  id varchar(36) [pk, not null]
  section_id varchar(36) [not null]
  product_id varchar(36) [not null, unique]
  quantity int [not null, default: 0]
  created_at timestamp [not null, default: `(now())`]
  updated_at timestamp [not null, default: `(now())`]

  indexes {
    section_id [name: 'section_product_section_id_idx']
    product_id [name: 'section_product_product_id_idx']
  }
}

ref refresh_sessions_user_id_app_user_id_fk: refresh_sessions.user_id > app_user.id [delete: cascade, update: no action]

ref role_permission_role_key_roles_key_fk: role_permission.role_key > roles.key [delete: cascade, update: no action]

ref role_permission_permission_key_permission_key_fk: role_permission.permission_key > permission.key [delete: cascade, update: no action]

ref app_user_role_key_roles_key_fk: app_user.role_key > roles.key [delete: cascade, update: no action]

ref product_refiller_product_product_id_fk: product_refiller.product > product.id [delete: cascade, update: no action]

ref product_refiller_refiller_app_user_id_fk: product_refiller.refiller > app_user.id [delete: cascade, update: no action]

ref shelf_product_id_product_id_fk: shelf.product_id > product.id [delete: cascade, update: no action]

ref section_store_room_id_store_room_id_fk: section.store_room_id > store_room.id [delete: cascade, update: no action]

ref section_product_section_id_section_id_fk: section_product.section_id > section.id [delete: cascade, update: no action]

ref section_product_product_id_product_id_fk: section_product.product_id > product.id [delete: cascade, update: no action]